# ============================================
#  FLASHLOAN-AI — Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================

# === REQUIRED ===
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
ARBITRUM_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# === OPTIONAL — Additional Networks ===
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com

# === OPTIONAL — Block Explorer API Keys (for contract verification) ===
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
POLYGONSCAN_API_KEY=

# === OPTIONAL — Telegram Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === OPTIONAL — Hardhat Fork Mode ===
FORK_ENABLED=false
