{
  "name": "flashloan-ai",
  "version": "1.0.0",
  "description": "Automated Flashloan Arbitrage Bot - Multi-chain, Multi-DEX",
  "main": "bot/monitor.js",
  "scripts": {
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network arbitrum",
    "deploy:arbitrum": "npx hardhat run scripts/deploy.js --network arbitrum",
    "deploy:base": "npx hardhat run scripts/deploy.js --network base",
    "bot": "node bot/index.js --arb",
    "bot:all": "node bot/index.js --all",
    "bot:arb": "node bot/index.js --arb",
    "bot:liq": "node bot/index.js --liq",
    "bot:stable": "node bot/index.js --stable",
    "bot:liquidation": "node bot/liquidation-bot.js",
    "bot:liquidation:base": "node bot/liquidation-bot.js base",
    "bot:stablecoin": "node bot/stablecoin-scanner.js",
    "bot:stablecoin:base": "node bot/stablecoin-scanner.js base",
    "test": "npx hardhat test",
    "server": "node server/app.js",
    "server:dev": "node server/app.js",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:stop": "npx pm2 stop flashloan-server",
    "pm2:restart": "npx pm2 restart flashloan-server",
    "pm2:status": "npx pm2 status",
    "pm2:logs": "npx pm2 logs flashloan-server",
    "pm2:save": "npx pm2 save",
    "pm2:startup": "npx pm2 startup"
  },
  "dependencies": {
    "@aave/core-v3": "^1.19.3",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "hardhat": "^2.19.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "pm2": "^5.3.0",
    "qrcode": "^1.5.4",
    "simple-statistics": "^7.8.9",
    "socket.io": "^4.7.4"
  }
}
